{
  "name": "@senior-robot/source",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "pnpm run svg && nx serve blog",
    "start:host": "pnpm run svg && nx serve blog --host",
    "start:prod": "pnpm run svg && pnpm nx serve blog --configuration=production",
    "build": "pnpm run svg && pnpm nx build blog",
    "svg": "svg-generator"
  },
  "svgGenerator": {
    "outputPath": "./blog/src/app/svg/",
    "srcPath": "./blog/src/public/assets/",
    "svgoConfig": {
      "plugins": [
        "removeDimensions",
        "cleanupAttrs",
        {
          "name": "convertColors",
          "params": {
            "currentColor": true
          }
        }
      ]
    }
  },
  "private": false,
  "dependencies": {
    "@analogjs/content": "2.6.3",
    "@analogjs/router": "2.6.3",
    "@angular/animations": "21.1.6",
    "@angular/common": "21.1.6",
    "@angular/compiler": "21.1.6",
    "@angular/core": "21.1.6",
    "@angular/forms": "21.1.6",
    "@angular/localize": "21.1.6",
    "@angular/platform-browser": "21.1.6",
    "@angular/platform-browser-dynamic": "21.1.6",
    "@angular/platform-server": "21.1.6",
    "@angular/router": "21.1.6",
    "@angular/ssr": "21.1.5",
    "@ngneat/overview": "^6.1.1",
    "@ngneat/svg-icon": "^8.0.0",
    "@ngxpert/hot-toast": "^6.1.0",
    "dotenv": "^16.4.7",
    "front-matter": "^4.0.2",
    "luxon": "^3.4.0",
    "mailtrap": "^4.5.0",
    "marked": "^15.0.7",
    "marked-gfm-heading-id": "^4.1.1",
    "marked-highlight": "^2.2.1",
    "marked-mangle": "^1.1.10",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@analogjs/platform": "2.6.3",
    "@analogjs/vite-plugin-angular": "2.6.3",
    "@angular-devkit/build-angular": "21.1.5",
    "@angular-devkit/core": "21.1.5",
    "@angular-devkit/schematics": "21.1.5",
    "@angular-eslint/eslint-plugin": "19.0.2",
    "@angular-eslint/eslint-plugin-template": "19.0.2",
    "@angular-eslint/template-parser": "19.0.2",
    "@angular/cli": "21.1.5",
    "@angular/compiler-cli": "21.1.6",
    "@angular/language-service": "21.1.6",
    "@ngneat/svg-generator": "^7.0.2",
    "@nx/angular": "22.5.4",
    "@nx/cypress": "22.5.4",
    "@nx/devkit": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/vite": "22.5.4",
    "@nx/vitest": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@schematics/angular": "21.1.5",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/typography": "^0.5.20",
    "@types/luxon": "^3.3.4",
    "@types/node": "20.19.37",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@typescript-eslint/utils": "7.18.0",
    "@vercel/node": "^2.15.9",
    "cypress": "15.9.0",
    "daisyui": "^5.6.18",
    "destr": "^2.0.1",
    "jiti": "2.4.2",
    "jsdom": "^22.1.0",
    "nx": "22.5.4",
    "postcss": "^8.4.27",
    "prettier": "^3.0.1",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "tailwindcss": "^4.3.3",
    "typescript": "5.9.2",
    "vite": "7.3.1",
    "vitest": "^4.0.0"
  }
}
